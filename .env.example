# ── Supabase (Frontend + Backend) ───────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# Vite exposes VITE_ prefixed vars to the browser
VITE_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
VITE_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=postgres://user:pass@host:port/postgres?sslmode=require
# Fallbacks: POSTGRES_PRISMA_URL, POSTGRES_URL also accepted

# ── Kimi AI API ────────────────────────────────────────────────
KIMI_API_KEY=your-kimi-api-key
KIMI_BASE_URL=https://api.moonshot.cn/v1

# ── Security ───────────────────────────────────────────────────
JWT_SECRET=your-random-secret-key-min-32-chars
CRON_SECRET=your-cron-secret-for-cron-jobs-org

# ── Optional ───────────────────────────────────────────────────
KIMI_AUTH_URL=https://auth.kimi.com
KIMI_OPEN_URL=https://open.kimi.com
OWNER_UNION_ID=
