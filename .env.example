# ── Supabase (Frontend + Backend) ───────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# Vite exposes VITE_ prefixed vars to the browser
VITE_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
VITE_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=postgres://user:pass@host:port/postgres?sslmode=require
# Fallbacks (auto-detected): POSTGRES_URL_NON_POOLING, POSTGRES_URL, POSTGRES_PRISMA_URL

# ── AI API (Primary - Kimi Code / OpenAI-compatible) ────────────
# Kimi (Moonshot): https://platform.moonshot.cn
# For Kimi Code API, use model: moonshot-v1-32k or moonshot-v1-8k
AI_API_KEY=your-kimi-api-key
AI_BASE_URL=https://api.moonshot.cn/v1
AI_MODEL=moonshot-v1-128k

# ── AI API (Fallback - MiniMax) ────────────────────────────────
MINIMAX_API_KEY=your-minimax-key
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=abab6.5s-chat

# ── Cron Jobs ──────────────────────────────────────────────────
# Get API key from: https://cron-job.org
CRON_JOBS_ORG_API_KEY=your-cron-jobs-org-api-key
CRON_SECRET=your-random-cron-secret-min-32-chars

# ── Security ───────────────────────────────────────────────────
JWT_SECRET=your-random-secret-key-min-32-chars

# ── Optional ───────────────────────────────────────────────────
KIMI_AUTH_URL=https://auth.kimi.com
KIMI_OPEN_URL=https://open.kimi.com
OWNER_UNION_ID=
