# ── Supabase (Frontend + Backend) ───────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# Vite exposes VITE_ prefixed vars to the browser
VITE_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
VITE_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=postgres://user:pass@host:port/postgres?sslmode=require
# Fallbacks: POSTGRES_URL_NON_POOLING, POSTGRES_URL, POSTGRES_PRISMA_URL

# ── AI API (OpenAI-compatible) ─────────────────────────────────
# Works with: Moonshot (Kimi), OpenAI, Groq, Together, local models, etc.
# Option 1: Generic names (recommended)
AI_API_KEY=your-api-key
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o

# Option 2: Legacy Moonshot names (still supported)
# KIMI_API_KEY=your-kimi-key
# KIMI_BASE_URL=https://api.moonshot.cn/v1
# KIMI_MODEL=moonshot-v1-128k

# ── Security ───────────────────────────────────────────────────
JWT_SECRET=your-random-secret-key-min-32-chars
CRON_SECRET=your-cron-secret-for-cron-jobs-org

# ── Optional ───────────────────────────────────────────────────
KIMI_AUTH_URL=https://auth.kimi.com
KIMI_OPEN_URL=https://open.kimi.com
OWNER_UNION_ID=
